# =============================================================================
# Variables de entorno — Anguila Lottery System
# =============================================================================
# Copia este archivo a `.env` cuando trabajes FUERA de Lovable (local, CI, etc.)
# En Lovable, el .env se genera automáticamente — NO lo subas a GitHub.
#
# Obtén los valores reales en:
#   Lovable → Cloud → Backend → Connect
# =============================================================================

# --- Cliente (browser, expuestos con prefijo VITE_) ---
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key-publica>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# --- Server / SSR (mismas URLs, sin prefijo VITE_) ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon-key-publica>"

# --- Server SOLO — bypass de RLS, NUNCA exponer al cliente ---
SUPABASE_SERVICE_ROLE_KEY="<service-role-key-secreta>"

# --- Opcionales (gestionados en Lovable Cloud → Secrets) ---
# LOVABLE_API_KEY="<para Lovable AI Gateway>"
# SUPABASE_DB_URL="postgres://..."
